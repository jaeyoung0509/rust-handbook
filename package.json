{
  "name": "rust-handbook",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint:md": "markdownlint-cli2 README.md \"docs/**/*.md\"",
    "lint:frontmatter": "tsx scripts/validate-frontmatter.mts",
    "lint:mermaid": "tsx scripts/validate-mermaid.mts",
    "lint:links": "tsx scripts/validate-links.mts",
    "check:docs": "pnpm lint:md && pnpm lint:frontmatter && pnpm lint:mermaid && pnpm lint:links && pnpm docs:build",
    "check:rust": "cargo fmt --all --check && cargo clippy --workspace --all-targets -- -D warnings && cargo test --workspace",
    "verify": "pnpm check:docs && pnpm check:rust"
  },
  "dependencies": {
    "mermaid": "^11.13.0",
    "vitepress": "^1.6.4",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "fast-glob": "^3.3.3",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "jsdom": "^28.1.0",
    "markdown-it": "^14.1.0",
    "markdownlint-cli2": "^0.18.1",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
